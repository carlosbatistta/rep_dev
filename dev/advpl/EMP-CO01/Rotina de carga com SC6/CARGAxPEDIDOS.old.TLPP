▒▒║          │                                                            ║▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
//Static Function MontArq(aCols,aHeader)
Static Function MontArq()

Local a_Stru:={}
Local c_String := ""
Local nAtual := 0

c_String += "SELECT C5_FILIAL,C5_NUM,C5_EMISSAO,C5_VEND1,C5_CLIENTE,C5_LOJACLI,C5_XNOMCLI " 
If SC5->(FieldPos("C5_YCARGA")) > 0 	//valida se existe o campo na SX3
     c_String += CHR(13) + ",C5_YCARGA " 
EndIf
//,C5_YCARGA,C6_YCARGA
If SC6->(FieldPos("C6_YCARGA")) > 0 	//valida se existe o campo na SX3
     c_String += CHR(13) + ",C6_YCARGA " 
EndIf
c_String += ",C6_ITEM,C6_PRODUTO,C6_DESCRI  "
c_String += CHR(13) + "FROM " + RETSQLNAME("SC5") + " SC5 "
c_String += CHR(13) + "INNER JOIN " + RetSqlName("SC6") +" SC6 ON C6_FILIAL = C5_FILIAL AND C6_NUM = C5_NUM AND (C6_NOTA = ' ' OR C6_NOTA = '') AND SC6.D_E_L_E_T_ <> '*' "  
c_String += CHR(13) + "LEFT JOIN " + RetSqlName("SA1") +" SA1 ON A1_FILIAL = '" + xFilial("SA1") +"' AND A1_COD = C5_CLIENTE AND A1_LOJA = C5_LOJACLI AND SA1.D_E_L_E_T_ <> '*' "  
//c_String += CHR(13) + "LEFT JOIN " + RetSqlName("SC9") +" SC9 ON C9_FILIAL = C5_FILIAL AND C9_PEDIDO = C5_NUM AND C9_ITEM = C6_ITEM AND C9_PRODUTO = C6_PRODUTO AND (C9_NFISCAL = ' ' OR C9_NFISCAL = '') AND SC9.D_E_L_E_T_ <> '*' "  
c_String += CHR(13) + "WHERE C5_FILIAL='" + xFilial("SC5") +"' AND SC5.D_E_L_E_T_=' ' "
c_String += CHR(13) + "AND (C5_NOTA = ' ' OR C5_NOTA = '') "
c_String += CHR(13) + "AND C5_EMISSAO BETWEEN '"+Dtos(mv_par01)+"' AND '"+Dtos(mv_par02)+"' "
c_String += CHR(13) + "AND C5_VEND1 BETWEEN '"+Alltrim(mv_par03)+"' AND '"+Alltrim(mv_par04)+"' "
c_String += CHR(13) + "AND C6_PRODUTO BETWEEN '"+Alltrim(mv_par05)+"' AND '"+Alltrim(mv_par06)+"' "
//##########################################
// Estados a serem considerados
// Tratamento para a pergunta ficar no formato para o SQL. Ex: 'PE','PB','CE'
If !Empty(Alltrim(MV_PAR07))

     aEstados := strtokarr (Alltrim(MV_PAR07),",")  //converto para Arrey
     nAtual   := 0
     cEST := "" //nova variavel para concatenar os estados
     //Percorre as linhas do Arrey, e adiciona na nova variavel entre aspas simples ('cEST')
     For nAtual := 1 To Len(aEstados)
         cEST += "'" + aEstados[nAtual] + "'"
         If nAtual < Len(aEstados) //se nao for a ultimia linha, adiciona virgula
           cEST += ","
         EndIf
     Next nAtual
     c_String += CHR(13) + "AND A1_EST IN (" + cEST + ")"
EndIf
//##########################################
c_String += CHR(13) + "ORDER BY C5_EMISSAO,C5_NUM,C6_ITEM "
MEMOWRITE( "c:\query\CargaXPedidos.txt",c_String)

TCQUERY c_String Alias TC6 New

//aadd(a_Stru,{"MARK", "C",2,0})
AADD(a_Stru,{"C5_OK"     ,"C",2,0})
AADD(a_Stru,{"C5_FILIAL" ,"C",TamSX3("C5_FILIAL" )[1],0})
AADD(a_Stru,{"C5_NUM"    ,"C",TamSX3("C5_NUM"    )[1],0})
AADD(a_Stru,{"C5_EMISSAO","D",TamSX3("C5_EMISSAO")[1],0})
AADD(a_Stru,{"C5_VEND1"  ,"C",TamSX3("C5_VEND1"  )[1],0})
AADD(a_Stru,{"C5_CLIENTE","C",TamSX3("C5_CLIENTE")[1],0})
AADD(a_Stru,{"C5_LOJACLI","C",TamSX3("C5_LOJACLI")[1],0})
AADD(a_Stru,{"C5_XNOMCLI","C",TamSX3("C5_XNOMCLI")[1],0})
If SC6->(FieldPos("C6_YCARGA")) > 0 	//valida se existe o campo na SX3
     AADD(a_Stru,{"C6_YCARGA" ,"C",TamSX3("C6_YCARGA" )[1],0})
EndIf
AADD(a_Stru,{"C6_ITEM"   ,"C",TamSX3("C6_ITEM"   )[1],0})
AADD(a_Stru,{"C6_PRODUTO","C",TamSX3("C6_PRODUTO")[1],0})
AADD(a_Stru,{"C6_DESCRI" ,"C",TamSX3("C6_DESCRI" )[1],0})
aadd(a_Stru,{"CORDEF"    ,"C",1,0})

c_Arq := CriaTrab(a_Stru,.t.)

dbUseArea(.t.,,c_Arq,"TMPP",.f.,.f.)

INDEX ON C5_EMISSAO TO (c_Arq+"1")
INDEX ON C5_NUM TO (c_Arq+"2")
INDEX ON C6_ITEM TO (c_Arq+"3")
SET index to (c_Arq+"1"),(c_Arq+"2"),(c_Arq+"3")

TMPP->(DBGOTOP())

APPEND FROM TC6

Return


/*/
+-----------------------------------------------------------------------------
| Programa | CriarCarga | Autor | Luciano                    | Data |28/10/24|
+-----------------------------------------------------------------------------
| Desc. | Criar a carga com os pedidos selecionados da MarkBrowse            |  
+-----------------------------------------------------------------------------
| Uso | 										     			  |
+-----------------------------------------------------------------------------
/*/

User Function CriarCarga()

//ApMsgInfo("Rotina em desenvolvimento","CriarCarga()")

Local cMarca := ThisMark()
//Local lInvert := ThisInv()
Local nRetSQL := 0
Local cNovaCarga := ""
Local l_OK := .T. 
Local aArea := GetArea()

//##############################
// valida se o campo da carga existe na SX3
If !(SC6->(FieldPos("C6_YCARGA")) > 0 ) //se nao existir
     cTexto := "Carga nŃo pode ser gerada." + CHR(13)
     cTexto += "o campo C6_YCARGA nŃo existe na base. Acionar Suporte." + CHR(13)
     MsgStop(cTexto)
     RestArea(aArea)
     Return()
EndIf

If !(SC9->(FieldPos("C9_YCARGA")) > 0 ) //se nao existir
     cTexto := "Rotina de cancelamento nŃo pode ser iniciada." + CHR(13)
     cTexto += "O campo C9_YCARGA nŃo existe na base. Acionar Suporte." + CHR(13)
     MsgStop(cTexto)
     Return()
EndIf

//##############################
// valida se jah existe carga gerada para os itens selecionados
TMPP->(DbGoTop())
Set Filter to C5_OK == cMarca 
While !TMPP->(EOF())
	IF TMPP->C5_OK == cMarca 
          If !Empty(TMPP->C6_YCARGA)
               ApMsgInfo("Item selecionado jß contķm carga gerada.","CriarCarga()")
               TMPP->(dbClearFilter())
               TMPP->(DbGoTop())
               RestArea(aArea)
               Return()
          EndIf
	endif
	TMPP->(dbSkip())
End

//##############################
// Novo numero da carga
cNovaCarga := GETSX8NUM("SC9","C9_YCARGA")
ConfirmSX8()
//cNovaCarga := "123456"

//##############################
// Atualiza os pedidos com o numero da carga 
TMPP->(dbClearFilter())
TMPP->(DbGoTop())
Set Filter to C5_OK == cMarca 
While !TMPP->(EOF())
	IF TMPP->C5_OK == cMarca //.AND. !lInvert

          //##############################
          // valida se o campo da carga existe na SX3
          If (SC5->(FieldPos("C5_YCARGA")) > 0 ) //se existir
               cSqlUpd := "" //Atualiza na SC5 ?
               cSqlUpd += CHR(13) + "UPDATE "+RetSQLName("SC5")+" SET C5_YCARGA = '"+cNovaCarga+"' " 
               cSqlUpd += CHR(13) + "WHERE C5_FILIAL = '"+xFilial("SC5")+"' "
               cSqlUpd += CHR(13) + "AND C5_NUM = '"+TMPP->C5_NUM+"' "
               //cSqlUpd += CHR(13) + "AND C5_YCARGA = ' ' "
               cSqlUpd += CHR(13) + "AND D_E_L_E_T_ <> '*' "

               nRetSQL := TcSqlExec(cSqlUpd)
               If nRetSQL < 0  // -1 se erro
                    ApMsgInfo("Erro ao gravar a carga "+cNovaCarga+" na SC5","CriarCarga()")
                    l_OK := .F.
               EndIf
               cSqlUpd := ""
          EndIf
          
          // ATUALIZA NA SC6
          cSqlUpd := ""
          cSqlUpd += CHR(13) + "UPDATE "+RetSQLName("SC6")+" SET C6_YCARGA = '"+cNovaCarga+"' " 
          cSqlUpd += CHR(13) + "WHERE C6_FILIAL = '"+xFilial("SC6")+"' "
          cSqlUpd += CHR(13) + "AND C6_NUM = '"+TMPP->C5_NUM+"' "
          cSqlUpd += CHR(13) + "AND C6_ITEM = '"+TMPP->C6_ITEM+"' "
          cSqlUpd += CHR(13) + "AND C6_PRODUTO = '"+TMPP->C6_PRODUTO+"' "
          cSqlUpd += CHR(13) + "AND C6_YCARGA = ' ' "
          cSqlUpd += CHR(13) + "AND D_E_L_E_T_ <> '*' "

          nRetSQL := TcSqlExec(cSqlUpd)
          If nRetSQL < 0  // -1 se erro
               ApMsgInfo("Erro ao gravar a carga "+cNovaCarga+" na SC6","CriarCarga()")
               l_OK := .F.
          EndIf
          cSqlUpd := ""


          // ATUALIZA NA SC9
          cSqlUpd := ""
          cSqlUpd += CHR(13) + "UPDATE "+RetSQLName("SC9")+" SET C9_YCARGA = '"+cNovaCarga+"' " 
          cSqlUpd += CHR(13) + "WHERE C9_FILIAL = '"+xFilial("SC9")+"' "
          cSqlUpd += CHR(13) + "AND C9_PEDIDO = '"+TMPP->C5_NUM+"' "
          cSqlUpd += CHR(13) + "AND C9_ITEM = '"+TMPP->C6_ITEM+"' "
          cSqlUpd += CHR(13) + "AND C9_PRODUTO = '"+TMPP->C6_PRODUTO+"' "
          cSqlUpd += CHR(13) + "AND C9_YCARGA = ' ' "
          cSqlUpd += CHR(13) + "AND D_E_L_E_T_ <> '*' "

          nRetSQL := TcSqlExec(cSqlUpd)
          If nRetSQL < 0  // -1 se erro
               ApMsgInfo("Erro ao gravar a carga "+cNovaCarga+" na SC9","CriarCarga()")
               l_OK := .F.
          EndIf
          cSqlUpd := ""

          //Inclui na SC9
          dbSelectArea("SC9")
          SC9->(dbSetOrder(1)) //C9_FILIAL+C9_PEDIDO+C9_ITEM+C9_SEQUEN+C9_PRODUTO
          If !dbSeek(xFilial("SC9")+TMPP->C5_NUM+TMPP->C6_ITEM)
               RecLock("SC9",.T.)
               SC9->C9_FILIAL := xFilial("SC9")
               SC9->C9_OK := " "
               SC9->C9_PEDIDO := TMPP->C5_NUM
               SC9->C9_ITEM   := TMPP->C6_ITEM
               SC9->C9_CLIENTE:= TMPP->C5_CLIENTE
               SC9->C9_LOJA   := TMPP->C5_LOJACLI
               SC9->C9_PRODUTO:= TMPP->C6_PRODUTO
               SC9->C9_QTDLIB := 0
               SC9->C9_YCARGA := cNovaCarga
               SC9->(MsUnLock())
          EndIf

          //Atualiza na Tela
          If Empty(TMPP->C6_YCARGA)
               RecLock("TMPP",.F.)
               TMPP->C6_YCARGA := cNovaCarga
               TMPP->(MsUnLock())
          EndIf

	endif
	TMPP->(dbSkip())
End

If !l_OK
     MsgStop("Erro ao gravar a carga "+cNovaCarga)
Else
     ApMsgInfo("Carga "+cNovaCarga+" Gerada com sucesso.","CriarCarga()")
EndIf

TMPP->(dbClearFilter())
TMPP->(DbGoTop())

RestArea(aArea)
Return()


//###########################################
//Imprimir a carga (Espelho de carga)
//User Function PRINTCARGA()
//ApMsgInfo("Rotina em desenvolvimento","CriarCarga()")
//Return()


//###########################################
// Cancelar a Carga
//###########################################
User Function CANCELCARGA()
//ApMsgInfo("Rotina em desenvolvimento","CANCELCARGA()")
Local aArea := GetArea()
Local oSay1
Local oSay2
Local oSay3
Local oSButton1
Local oSButton2
Local cDetalhe := " "
Local oGet1
Local cCarga := "" //Space(TamSX3("C6_YCARGA")[1])
Local dDatade 	:= Date()
Local oGet2
Local dDataAte := Date()
Static oDlg

//##############################
// valida se o campo da carga existe na SX3
If !(SC6->(FieldPos("C6_YCARGA")) > 0 ) //se nao existir
     cTexto := "Rotina de cancelamento nŃo pode ser iniciada." + CHR(13)
     cTexto += "O campo C6_YCARGA nŃo existe na base. Acionar Suporte." + CHR(13)
     MsgStop(cTexto)
     Return()
EndIf

cDetalhe := "Cancelamento de Carga. " + CRLF
cDetalhe += "ATENŪ├O: Esta ańŃo nŃo pode ser desfeita." + CRLF
cDetalhe += " " + CRLF

cCarga := Space(TamSX3("C6_YCARGA")[1])

  DEFINE MSDIALOG oDlg TITLE "Cancelamento de Carga" FROM 000, 000  TO 250, 400 COLORS 0, 16777215 PIXEL

    @ 004, 007 SAY oSay1 PROMPT cDetalhe SIZE 173, 042 OF oDlg COLORS 0, 16777215 PIXEL

     @ 030, 007 SAY oSay2 PROMPT "N. Carga" SIZE 025, 007 OF oDlg COLORS 0, 16777215 PIXEL
     @ 030, 045 MSGET oGet1 VAR cCarga SIZE 060, 010 OF oDlg COLORS 0, 16777215 PIXEL
     //@ 045, 007 SAY oSay3 PROMPT "Data Ate" SIZE 025, 007 OF oDlg COLORS 0, 16777215 PIXEL
     //@ 045, 045 MSGET oGet2 VAR dDataAte SIZE 060, 010 OF oDlg COLORS 0, 16777215 PIXEL
 
    DEFINE SBUTTON oSButton1 FROM 110, 068 TYPE 01 OF oDlg ENABLE ACTION (LJMsgRun(OemToAnsi('Aguarde... Processando...'),,{ || DELCARGA(cCarga) }),oDlg:End())
    DEFINE SBUTTON oSButton2 FROM 110, 114 TYPE 02 OF oDlg ENABLE ACTION oDlg:End()

  ACTIVATE MSDIALOG oDlg CENTERED

RestArea(aArea)
Return()


Static Function DELCARGA(cCarga)

//ApMsgInfo("Rotina em desenvolvimento","CANCELCARGA()")

//verifico se encontrou a carga
cQuery := "SELECT C6_YCARGA,C6_NOTA "
cQuery += CHR(13) + "FROM "+ RetSqlName("SC6") +" SC6 "
cQuery += CHR(13) + "WHERE C6_FILIAL = '"+xFilial("SC6")+"' "
cQuery += CHR(13) + "AND SC6.D_E_L_E_T_ <> '*' "
cQuery += CHR(13) + "AND C6_YCARGA = '"+cCarga+"' "

TcQuery cQuery new alias "TP01"
DbSelectArea("TP01")
If Empty(TP01->C6_YCARGA)
     MsgStop("Carga "+cCarga+" nŃo encontrada na SC6.","NŃo hß dados!")
     TP01->(dbCloseArea())
     Return()
Endif

If !Empty(TP01->C6_NOTA)  //se tem nota
     MsgStop("A Carga nŃo pode ser cancelada, pois o pedido jß foi faturada.","Carga Faturada")
     TP01->(dbCloseArea())
     Return()
Endif

if !(MsgYesNo("Deseja realmente cancelar a Carga " + cCarga + " ? "))
     TP01->(dbCloseArea())
     Return()
EndIf
TP01->(dbCloseArea())

If SC5->(FieldPos("C5_YCARGA")) > 0 //se existe o campo
     cSqlUpd := "" //Atualiza na SC5
     cSqlUpd += CHR(13) + "UPDATE "+RetSQLName("SC5")+" SET C5_YCARGA = ' ' " 
     cSqlUpd += CHR(13) + "WHERE C5_FILIAL = '"+xFilial("SC5")+"' "
     //cSqlUpd += CHR(13) + "AND C5_NUM = '"+TMPP->C5_NUM+"' "
     cSqlUpd += CHR(13) + "AND C5_YCARGA = '"+cCarga+"' "
     cSqlUpd += CHR(13) + "AND D_E_L_E_T_ <> '*' "

     nRetSQL := TcSqlExec(cSqlUpd)
     If nRetSQL < 0  // -1 se erro
          ApMsgInfo("Erro ao cancelar a carga "+cCarga+" na SC5","CancelCarga()")
          l_OK := .F.
     EndIf
     cSqlUpd := ""
EndIf

// ATUALIZA NA SC6
cSqlUpd := ""
cSqlUpd += CHR(13) + "UPDATE "+RetSQLName("SC6")+" SET C6_YCARGA = ' ' " 
cSqlUpd += CHR(13) + "WHERE C6_FILIAL = '"+xFilial("SC6")+"' "
cSqlUpd += CHR(13) + "AND C6_YCARGA = '"+cCarga+"' "
cSqlUpd += CHR(13) + "AND D_E_L_E_T_ <> '*' "

nRetSQL := TcSqlExec(cSqlUpd)
If nRetSQL < 0  // -1 se erro
     ApMsgInfo("Erro ao cancelar a carga "+cCarga+" na SC6","CancelCarga()")
     l_OK := .F.
EndIf
cSqlUpd := ""

// ATUALIZA NA SC9
cSqlUpd := ""
cSqlUpd += CHR(13) + "UPDATE "+RetSQLName("SC9")+" SET C9_YCARGA = ' ' " 
cSqlUpd += CHR(13) + "WHERE C9_FILIAL = '"+xFilial("SC9")+"' "
cSqlUpd += CHR(13) + "AND C9_YCARGA = '"+cCarga+"' "
cSqlUpd += CHR(13) + "AND D_E_L_E_T_ <> '*' "

nRetSQL := TcSqlExec(cSqlUpd)
If nRetSQL < 0  // -1 se erro
     ApMsgInfo("Erro ao cancelar a carga "+cCarga+" na SC9","CancelCarga()")
     l_OK := .F.
EndIf
cSqlUpd := ""

//Atualiza na Tela

TMPP->(DbGoTop())
While TMPP->(!EOF())
     If TMPP->C6_YCARGA == cCarga
          RecLock("TMPP",.F.)
          TMPP->C6_YCARGA := Space(TamSX3("C6_YCARGA")[1])
          MsUnLock()
     EndIf
     TMPP->(dbSkip())
End

TMPP->(dbClearFilter())
TMPP->(DbGoTop())

ApMsgInfo("Carga "+cCarga+" ExcluĒda.","CancelCarga()")
U_LimpaTodos()
Return()



//###########################################
//Criar perguntas na SX1 
// Funcao substituta do PutSx1 (que foi descontinuada no P12)
//###########################################
Static Function xPutSx1(cGrupo,cOrdem,cPergunt,cPerSpa,cPerEng,cVar,; 
     cTipo ,nTamanho,nDecimal,nPresel,cGSC,cValid,; 
     cF3, cGrpSxg,cPyme,; 
     cVar01,cDef01,cDefSpa1,cDefEng1,cCnt01,; 
     cDef02,cDefSpa2,cDefEng2,; 
     cDef03,cDefSpa3,cDefEng3,; 
     cDef04,cDefSpa4,cDefEng4,; 
     cDef05,cDefSpa5,cDefEng5,; 
     aHelpPor,aHelpEng,aHelpSpa,cHelp) 

LOCAL aArea := GetArea() 
Local cKey 
Local lPort := .f. 
Local lSpa := .f. 
Local lIngl := .f. 

cKey := "P." + AllTrim( cGrupo ) + AllTrim( cOrdem ) + "." 

cPyme    := Iif( cPyme           == Nil, " ", cPyme          ) 
cF3      := Iif( cF3           == NIl, " ", cF3          ) 
cGrpSxg := Iif( cGrpSxg     == Nil, " ", cGrpSxg     ) 
cCnt01   := Iif( cCnt01          == Nil, "" , cCnt01      ) 
cHelp      := Iif( cHelp          == Nil, "" , cHelp          ) 

dbSelectArea( "SX1" ) 
dbSetOrder( 1 ) 

// Ajusta o tamanho do grupo. Ajuste emergencial para valida├¦├Żo dos fontes. 
// RFC - 15/03/2007 
cGrupo := PadR( cGrupo , Len( SX1->X1_GRUPO ) , " " ) 

If !( DbSeek( cGrupo + cOrdem )) 

    cPergunt:= If(! "?" $ cPergunt .And. ! Empty(cPergunt),Alltrim(cPergunt)+" ?",cPergunt) 
     cPerSpa     := If(! "?" $ cPerSpa .And. ! Empty(cPerSpa) ,Alltrim(cPerSpa) +" ?",cPerSpa) 
     cPerEng     := If(! "?" $ cPerEng .And. ! Empty(cPerEng) ,Alltrim(cPerEng) +" ?",cPerEng) 

     Reclock( "SX1" , .T. ) 

     Replace X1_GRUPO   With cGrupo 
     Replace X1_ORDEM   With cOrdem 
     Replace X1_PERGUNT With cPergunt 
     Replace X1_PERSPA With cPerSpa 
     Replace X1_PERENG With cPerEng 
     Replace X1_VARIAVL With cVar 
     Replace X1_TIPO    With cTipo 
     Replace X1_TAMANHO With nTamanho 
     Replace X1_DECIMAL With nDecimal 
     Replace X1_PRESEL With nPresel 
     Replace X1_GSC     With cGSC 
     Replace X1_VALID   With cValid 

     Replace X1_VAR01   With cVar01 

     Replace X1_F3      With cF3 
     Replace X1_GRPSXG With cGrpSxg 

     If Fieldpos("X1_PYME") > 0 
          If cPyme != Nil 
               Replace X1_PYME With cPyme 
          Endif 
     Endif 

     Replace X1_CNT01   With cCnt01 
     If cGSC == "C"               // Mult Escolha 
          Replace X1_DEF01   With cDef01 
          Replace X1_DEFSPA1 With cDefSpa1 
          Replace X1_DEFENG1 With cDefEng1 

          Replace X1_DEF02   With cDef02 
          Replace X1_DEFSPA2 With cDefSpa2 
          Replace X1_DEFENG2 With cDefEng2 

          Replace X1_DEF03   With cDef03 
          Replace X1_DEFSPA3 With cDefSpa3 
          Replace X1_DEFENG3 With cDefEng3 

          Replace X1_DEF04   With cDef04 
          Replace X1_DEFSPA4 With cDefSpa4 
          Replace X1_DEFENG4 With cDefEng4 

          Replace X1_DEF05   With cDef05 
          Replace X1_DEFSPA5 With cDefSpa5 
          Replace X1_DEFENG5 With cDefEng5 
     Endif 

     Replace X1_HELP With cHelp 

     PutSX1Help(cKey,aHelpPor,aHelpEng,aHelpSpa) 

     MsUnlock() 
Else 

   lPort := ! "?" $ X1_PERGUNT .And. ! Empty(SX1->X1_PERGUNT) 
   lSpa := ! "?" $ X1_PERSPA .And. ! Empty(SX1->X1_PERSPA) 
   lIngl := ! "?" $ X1_PERENG .And. ! Empty(SX1->X1_PERENG) 

   If lPort .Or. lSpa .Or. lIngl 
          RecLock("SX1",.F.) 
          If lPort 
        SX1->X1_PERGUNT:= Alltrim(SX1->X1_PERGUNT)+" ?" 
          EndIf 
          If lSpa 
               SX1->X1_PERSPA := Alltrim(SX1->X1_PERSPA) +" ?" 
          EndIf 
          If lIngl 
               SX1->X1_PERENG := Alltrim(SX1->X1_PERENG) +" ?" 
          EndIf 
          SX1->(MsUnLock()) 
     EndIf 
Endif 

RestArea( aArea ) 

Return
