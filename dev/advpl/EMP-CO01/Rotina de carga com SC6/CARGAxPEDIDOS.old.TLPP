/*/{Protheus.doc} CARGAxPEDIDOS
FunńŃo cadastro de cargas de acordo com os pedidos selecionados
@author Carlos Batista
@since 28/10/2024
@version 1.0
/*/
USER FUNCTION CARGAxPEDIDOS()
Local aArea 		:= GetArea()
Local aCpos		:= {}
Local aCampos		:= {}
Local nI			:= 0
Local cAlias		:= "SC5"
Local cQuery 		:= {}
Local lAchou
Local cUser
local cPerg 	:= "CARGAXPED"
local aHelpPor:={} , aHelpEng:={} , aHelpSpa:={}

//Static cCodcli
Static dDtIni
Static dDtFin

//Private aRecSel 	:= {}
Private aRecSel 	:= {}
Private aRotina     := {}
Private cCadastro   := "Rotina de Carga x Pedidos"

If !(SC9->(FieldPos("C9_YCARGA")) > 0 ) //se nao existir
     cTexto := "Rotina nŃo pode ser iniciada." + CHR(13)
     cTexto += "O campo C9_YCARGA nŃo existe na base. Acionar Suporte." + CHR(13)
     MsgStop(cTexto)
     Return()
EndIf

If !(SC6->(FieldPos("C6_YCARGA")) > 0 ) //se nao existir
     cTexto := "Rotina nŃo pode ser iniciada." + CHR(13)
     cTexto += "O campo C6_YCARGA nŃo existe na base. Acionar Suporte." + CHR(13)
     MsgStop(cTexto)
     Return()
EndIf


xPutSx1(cPerg,"01","A partir da data? " ,"cPerSpa","cPerEng","MV_CH1","D",TamSX3("C5_EMISSAO")[1],0,0,"G",""," ","","","MV_PAR01")
xPutSx1(cPerg,"02",      "Ate a data? "	,"cPerSpa","cPerEng","MV_CH2","D",TamSX3("C5_EMISSAO")[1],0,0,"G",""," ","","","MV_PAR02")
xPutSx1(cPerg,"03","Vendedor de? " 	,"cPerSpa","cPerEng","MV_CH3","C",TamSX3("C5_VEND1")[1],0,0,"G","","SA3","","","MV_PAR03")
xPutSx1(cPerg,"04","Vendedor Ate? "	,"cPerSpa","cPerEng","MV_CH4","C",TamSX3("C5_VEND1" )[1],0,0,"G","","SA3","","","MV_PAR04")
xPutSx1(cPerg,"05","Produto de?"  ,"cPerSpa","cPerEng","MV_CH5","C" ,TamSX3("C6_PRODUTO")[1],0,0,"G","","SB1","","","MV_PAR05")
xPutSx1(cPerg,"06","Produto Ate?" ,"cPerSpa","cPerEng","MV_CH6","C",TamSX3("C6_PRODUTO")[1],0,0,"G","","SB1","","","MV_PAR06")
xPutSx1(cPerg,"07","UFs Selecionadas " ,"cPerSpa","cPerEng","MV_CH7","C",99,0,0,"G","","","","","MV_PAR07")

If !Pergunte(cPerg,.T.)
	Return
EndIf

//PRMUSER()

//no mßximo 10 bot§es
//AADD(aRotina,{"Pesquisar"	,"AxPesqui"	 ,0,1})
AADD(aRotina,{"Crigar Carga"	     ,"U_CriarCarga()" ,0,1})
AADD(aRotina,{"Marcar Todos"       ,"U_SelectTodos()" ,0,1})
AADD(aRotina,{"Limpar Marcacao"	,"U_LimpaTodos()" ,0,1})
//AADD(aRotina,{"Imprimir Carga"	,"U_PRINTCARGA()" ,0,1})
AADD(aRotina,{"Cancelar Carga"	,"U_CANCELCARGA()" ,0,1})
//AADD(aRotina,{"Visualizar"	,"AxVisual"	 ,0,4})
//AADD(aRotina,{"Incluir"		,"AxInclui"  ,0,4})
//AADD(aRotina,{"Excluir"		,"AxDeleta"	 ,0,5})

AADD(aCpos,"C5_OK")
AADD(aCpos,"C5_FILIAL")
AADD(aCpos,"C5_NUM")
AADD(aCpos,"C5_EMISSAO")
AADD(aCpos,"C5_CLIENTE")
AADD(aCpos,"C5_LOJACLI")
AADD(aCpos,"C5_XNOMCLI")
If SC6->(FieldPos("C6_YCARGA")) > 0 	//valida se existe o campo na SX3
     AADD(aCpos,"C6_YCARGA" )
EndIf
AADD(aCpos,"C6_ITEM"   )
AADD(aCpos,"C6_PRODUTO")
AADD(aCpos,"C6_DESCRI" )

dbSelectArea("SX3")
dbSetOrder(2)
For nI := 1 To Len(aCpos)
	IF dbSeek(aCpos[nI])
		aAdd(aCampos,{X3_CAMPO,"",Iif(nI==1,"",Trim(X3_TITULO)),Trim(X3_PICTURE)})
	ENDIF
Next
aCols := aCpos
aHeader := aCampos

MsgRun("Selecionando registros, Aguarde...","",{|| CursorWait(), montarq() ,CursorArrow()})

DbSelectArea("TMPP")
dbClearFilter()
DbSetOrder(1) 
Set Filter to (TMPP->C5_EMISSAO >= MV_PAR01 .AND. TMPP->C5_EMISSAO <= MV_PAR02)
MarkBrow("TMPP","C5_OK","CORDEF",aCampos,.F.,GetMark(,"TMPP","C5_OK"))

//DbSelectArea("SC5")
//DbSetOrder(1) 
//Set Filter to (SC5->C5_EMISSAO >= MV_PAR01 .AND. SC5->C5_EMISSAO <= MV_PAR02) //.AND. (SC5->C5_NUM >= MV_PAR03 .AND. SC5->C5_NUM <= MV_PAR04) 
//MarkBrow(cAlias,aCpos[1],"C5_NUM == ' '",aCampos,.F.,GetMark(,"SC5","C5_OK"))

RestArea(aArea)
Return


/*/
+-----------------------------------------------------------------------------
| Programa | MarcaTodos | Autor |                             | Data | |
+-----------------------------------------------------------------------------
| Desc. | FunńŃo utilizada para marcar todos os registros da MarkBrowse      |  
+-----------------------------------------------------------------------------
| Uso | 										     			  |
+-----------------------------------------------------------------------------
/*/
User FUNCTION SelectTodos()

TMPP->(DbGoTop())
While TMPP->(!EOF())
     RecLock("TMPP",.F.)
     TMPP->C5_OK := ThisMark()
     MsUnLock()
     TMPP->(dbSkip())
End

RETURN


/*/
+-----------------------------------------------------------------------------
| Programa | LimpaTodos | Autor |                             | Data | |
+-----------------------------------------------------------------------------
| Desc. | FunńŃo utilizada para limpar a marcacao de todos os registros da MarkBrowse     |
+-----------------------------------------------------------------------------
| Uso | 																	 |
+-----------------------------------------------------------------------------
/*/
User FUNCTION LimpaTodos()

TMPP->(DbGoTop())
While TMPP->(!EOF())
     RecLock("TMPP",.F.)
     TMPP->C5_OK := SPACE(2)
     MsUnLock()
     TMPP->(dbSkip())
End

RETURN


