#INCLUDE "RWMAKE.CH"
#include "TbiConn.ch"
#include "TbiCode.ch"
#INCLUDE "PROTHEUS.CH"
#include "topconn.ch"

/*/{Protheus.doc} PRINTCARGA
Relatorio das Cargas geradas (C6_YCARGA) Espelho de Carga
(Exportacao automatica para excel)
@author Carlos Batista
@since 13/11/2024
@version 1.0
/*/
#Define STR_PULA    Chr(13)+Chr(10)

User Function PRINTCARGA
Local aArea 	:= GetArea()
Local cQuery 	:= ""
Local oFWMsExcel
Local oExcel
Local cArquivo    := ""
Local aItensExcel := {}

Private cPerg 		:= "PRINTCARGA"
Private aPerg		:= {}

//##############################
// valida se o campo da carga existe na SX3
If !(SC6->(FieldPos("C6_YCARGA")) > 0 ) //se nao existir
     cTexto := "Carga năo pode ser gerada." + CHR(13)
     cTexto += "o campo C6_YCARGA năo existe na base. Acionar Suporte." + CHR(13)
     MsgStop(cTexto)
     RestArea(aArea)
     Return()
EndIf

//########################
//Cria as perguntas de usuario
xPutSx1(cPerg,"01","Numero da carga","cPerSpa","cPerEng","MV_CH1","C" ,TamSX3("C6_YCARGA")[1],0,0,"G","","","","","MV_PAR01")
//xPutSx1(cPerg,"02","Carga Ate: ","cPerSpa","cPerEng","MV_CH2","C",TamSX3("C6_YCARGA" )[1],0,0,"G","","SX3","","","MV_PAR02")

If !Pergunte(cPerg,.T.)
	Return
EndIf

//Criando o objeto que irĂˇ gerar o conteĂşdo do Excel
oFWMsExcel := FWMSExcel():New()

//Criando a Aba
cAba := "PRINTCARGA"
cTitulo := "Espelho de Carga: " + Alltrim(MV_PAR01)
//cTitulo := "Espelho de Carga: " + Alltrim(MV_PAR01) + " a " + Alltrim(MV_PAR02)
oFWMsExcel:AddworkSheet(cAba) 

//Criando a Tabela
oFWMsExcel:AddTable(cAba,cTitulo)

//Criando cabecalho das Colunas
oFWMsExcel:AddColumn(cAba,cTitulo,"Código",1,1)
oFWMsExcel:AddColumn(cAba,cTitulo,"Descriçăo",1,1)
oFWMsExcel:AddColumn(cAba,cTitulo,"Qtde.",1,1)
oFWMsExcel:AddColumn(cAba,cTitulo,"UN",1,1)
oFWMsExcel:AddColumn(cAba,cTitulo,"Cód.Fab.",1,1)
oFWMsExcel:AddColumn(cAba,cTitulo,"Nr.Lote",1,1)
oFWMsExcel:AddColumn(cAba,cTitulo,"Peso",1,1)
oFWMsExcel:AddColumn(cAba,cTitulo,"Preço Médio",1,1)

cQuery += CHR(13) + "SELECT C6_YCARGA,C6_PRODUTO,C6_LOTECTL,B1_CODBAR,B1_PESBRU,C6_UM,C6_DESCRI,SUM(C6_QTDVEN)C6_QTDVEN, SUM(C6_VALOR) AS TOTAL "
cQuery += CHR(13) + "FROM " + RETSQLNAME("SC6") + " SC6 " 
cQuery += CHR(13) + "INNER JOIN " + RetSqlName("SB1") +" SB1 ON B1_FILIAL = '"+ xFilial("SB1") +"' AND B1_COD = C6_PRODUTO AND SB1.D_E_L_E_T_ <> '*' "
cQuery += CHR(13) + "WHERE C6_FILIAL='" + xFilial("SC6") +"' AND SC6.D_E_L_E_T_ <> '*' "
//cQuery += CHR(13) + "AND C6_YCARGA BETWEEN '"+Alltrim(MV_PAR01)+"' AND '"+Alltrim(MV_PAR02)+"' " 
cQuery += CHR(13) + "AND C6_YCARGA = '"+Alltrim(MV_PAR01)+"' " 
cQuery += CHR(13) + "GROUP BY C6_YCARGA,C6_PRODUTO,C6_LOTECTL,B1_CODBAR,B1_PESBRU,C6_UM,C6_DESCRI "

MEMOWRITE( "c:\query\PRINTCARGA.txt",cQuery)
TcQuery cQuery Alias "TMP" NEW

//###########################################
//Criando as Linhas com o conteĂşdo das colunas
DbSelectArea("TMP")
TMP->(DbGoTop())
While TMP->(!EOF())
	
	oFWMsExcel:AddRow(cAba,cTitulo,{;
		Alltrim(TMP->C6_PRODUTO),;
		Alltrim(TMP->C6_DESCRI),;
		Alltrim(str(TMP->C6_QTDVEN)),;
		Alltrim(TMP->C6_UM),;
		Alltrim(TMP->B1_CODBAR),;
		Alltrim(TMP->C6_LOTECTL),;
		Alltrim(TMP->B1_PESBRU),;
		Alltrim(str(TMP->TOTAL/TMP->C6_QTDVEN)) })     
          // VARRER ANTES PARA PEGAR O TOTAL C6_VALOR / PELA QUANTIDADE DE PRODUTOS NA CARGA, LEMBRAR DO LOTE C6_LOTECTL

	TMP->(dbSkip())
EndDo

cQuery := ""
TMP->(dbCloseArea())


//###########################################
//salva na parta de arquivo temporĂˇrio do smart.
// uso data e segundos para nao repetir o nome do arquivo
cData := Alltrim(DtoS(Date()))
cSegundos := Alltrim(STR(Seconds()))
cArquivo    := GetTempPath()+cData+cSegundos+'-PRINTCARGA.xml' 

//###########################################
//Ativando o arquivo e gerando o xml
oFWMsExcel:Activate()
oFWMsExcel:GetXMLFile(cArquivo)

//verifico o sistema operacional
If GetRemoteType() == 1 // 1=Windows | 2=Linux/MacOS 

	//Abrindo o excel e abrindo o arquivo xml
	oExcel := MsExcel():New()             //Abre uma nova conexĂŁo com Excel
	oExcel:WorkBooks:Open(cArquivo)     //Abre uma planilha
	oExcel:SetVisible(.T.)                 //Visualiza a planilha
	oExcel:Destroy()                        //Encerra o processo do gerenciador de tarefas

Else
	ApMsgInfo(cArquivo,"Arquivo salvo em: ")
EndIf

RestArea(aArea)
Return



//###########################################
//Criar perguntas na SX1 
// Funcao substituta do PutSx1 (que foi descontinuada no P12)
//###########################################
Static Function xPutSx1(cGrupo,cOrdem,cPergunt,cPerSpa,cPerEng,cVar,; 
     cTipo ,nTamanho,nDecimal,nPresel,cGSC,cValid,; 
     cF3, cGrpSxg,cPyme,; 
     cVar01,cDef01,cDefSpa1,cDefEng1,cCnt01,; 
     cDef02,cDefSpa2,cDefEng2,; 
     cDef03,cDefSpa3,cDefEng3,; 
     cDef04,cDefSpa4,cDefEng4,; 
     cDef05,cDefSpa5,cDefEng5,; 
     aHelpPor,aHelpEng,aHelpSpa,cHelp) 

LOCAL aArea := GetArea() 
Local cKey 
Local lPort := .f. 
Local lSpa := .f. 
Local lIngl := .f. 

cKey := "P." + AllTrim( cGrupo ) + AllTrim( cOrdem ) + "." 

cPyme    := Iif( cPyme           == Nil, " ", cPyme          ) 
cF3      := Iif( cF3           == NIl, " ", cF3          ) 
cGrpSxg := Iif( cGrpSxg     == Nil, " ", cGrpSxg     ) 
cCnt01   := Iif( cCnt01          == Nil, "" , cCnt01      ) 
cHelp      := Iif( cHelp          == Nil, "" , cHelp          ) 

dbSelectArea( "SX1" ) 
dbSetOrder( 1 ) 

// Ajusta o tamanho do grupo. Ajuste emergencial para validaĂ§ĂŁo dos fontes. 
// RFC - 15/03/2007 
cGrupo := PadR( cGrupo , Len( SX1->X1_GRUPO ) , " " ) 

If !( DbSeek( cGrupo + cOrdem )) 

    cPergunt:= If(! "?" $ cPergunt .And. ! Empty(cPergunt),Alltrim(cPergunt)+" ?",cPergunt) 
     cPerSpa     := If(! "?" $ cPerSpa .And. ! Empty(cPerSpa) ,Alltrim(cPerSpa) +" ?",cPerSpa) 
     cPerEng     := If(! "?" $ cPerEng .And. ! Empty(cPerEng) ,Alltrim(cPerEng) +" ?",cPerEng) 

     Reclock( "SX1" , .T. ) 

     Replace X1_GRUPO   With cGrupo 
     Replace X1_ORDEM   With cOrdem 
     Replace X1_PERGUNT With cPergunt 
     Replace X1_PERSPA With cPerSpa 
     Replace X1_PERENG With cPerEng 
     Replace X1_VARIAVL With cVar 
     Replace X1_TIPO    With cTipo 
     Replace X1_TAMANHO With nTamanho 
     Replace X1_DECIMAL With nDecimal 
     Replace X1_PRESEL With nPresel 
     Replace X1_GSC     With cGSC 
     Replace X1_VALID   With cValid 

     Replace X1_VAR01   With cVar01 

     Replace X1_F3      With cF3 
     Replace X1_GRPSXG With cGrpSxg 

     If Fieldpos("X1_PYME") > 0 
          If cPyme != Nil 
               Replace X1_PYME With cPyme 
          Endif 
     Endif 

     Replace X1_CNT01   With cCnt01 
     If cGSC == "C"               // Mult Escolha 
          Replace X1_DEF01   With cDef01 
          Replace X1_DEFSPA1 With cDefSpa1 
          Replace X1_DEFENG1 With cDefEng1 

          Replace X1_DEF02   With cDef02 
          Replace X1_DEFSPA2 With cDefSpa2 
          Replace X1_DEFENG2 With cDefEng2 

          Replace X1_DEF03   With cDef03 
          Replace X1_DEFSPA3 With cDefSpa3 
          Replace X1_DEFENG3 With cDefEng3 

          Replace X1_DEF04   With cDef04 
          Replace X1_DEFSPA4 With cDefSpa4 
          Replace X1_DEFENG4 With cDefEng4 

          Replace X1_DEF05   With cDef05 
          Replace X1_DEFSPA5 With cDefSpa5 
          Replace X1_DEFENG5 With cDefEng5 
     Endif 

     Replace X1_HELP With cHelp 

     PutSX1Help(cKey,aHelpPor,aHelpEng,aHelpSpa) 

     MsUnlock() 
Else 

   lPort := ! "?" $ X1_PERGUNT .And. ! Empty(SX1->X1_PERGUNT) 
   lSpa := ! "?" $ X1_PERSPA .And. ! Empty(SX1->X1_PERSPA) 
   lIngl := ! "?" $ X1_PERENG .And. ! Empty(SX1->X1_PERENG) 

   If lPort .Or. lSpa .Or. lIngl 
          RecLock("SX1",.F.) 
          If lPort 
        SX1->X1_PERGUNT:= Alltrim(SX1->X1_PERGUNT)+" ?" 
          EndIf 
          If lSpa 
               SX1->X1_PERSPA := Alltrim(SX1->X1_PERSPA) +" ?" 
          EndIf 
          If lIngl 
               SX1->X1_PERENG := Alltrim(SX1->X1_PERENG) +" ?" 
          EndIf 
          SX1->(MsUnLock()) 
     EndIf 
Endif 

RestArea( aArea ) 

Return
