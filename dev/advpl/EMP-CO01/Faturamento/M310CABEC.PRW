#INCLUDE "RWMAKE.CH"

/*/{Protheus.doc} M310CABEC
Ponto de entrada da rotina MATA310 - TransferÍncia entre Filiais. Executada apůs a montagem do array aCabec antes das chamadas das rotinas automŠticas que 
ir„o gerar o cabeÁalho do pedido de vendas, do documento de entrada ou da fatura de entrada (localizado). … utilizado para permitir que o usuŠrio manipule 
o array aCabec que contťm os itens do cabeÁalho do pedido de vendas, documento de entrada ou fatura de entrada. … passado um par‚metro para identificar a 
rotina a ser executada apůs o ponto de entrada.
@author Carlos Batista
@since 28/11/2025
@version 1.0
/*/
User Function M310CABEC()
local cProg	:= ParamIXB[1]
local aCabec	:= ParamIXB[2]
local nPos  	:= 0
local aPerg 	:= {}
local aRet  	:= {}

if cProg == "MATA410"

   nPos:= ascan(aCabec,{|x| x[1] == 'C5_FORMAPG' })
   
   if nPos > 0
     	aCabec[nPos,02] := "NGF"
   else
		aadd(aCabec,{"C5_FORMAPG","NGF",NIL}) 
	endif

	aadd(aPerg,{1,"Cůdigo do transportador",space(TamSx3("A4_COD")[01]),"","","SA4","",0,.T.})
	
	while !( ParamBox(aPerg,"Par‚metro obrigatůrio (M310CABEC())",aRet) )
		MsgStop("… obrigatůrio informar o cůdigo do transportador!", "Informe o transportador") 
	enddo
	
   nPos:= ascan(aCabec,{|x| x[1] == 'C5_TRANSP' })
   
   if nPos > 0
     	aCabec[nPos,02] := aRet[1]
   else
		aadd(aCabec,{"C5_TRANSP",aRet[1],NIL}) 
	endif

endif

return aCabec
