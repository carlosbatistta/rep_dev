#include 'totvs.ch'
#include 'tlpp-core.th'

class CRUDClientes from fwAdapterBaseV2

	public method new() constructor

	@get('/v2/clientes')
	public method lista_cliente() as logical

    @get('/v2/cliente/:codigo/:loja')
	public method recupera_cliente() as logical

	@post('/v2/cliente')
	public method incluir_cliente() as logical

    @put('/v2/cliente')
    public method update_cliente() as logical

	@delete('/v2/cliente')
	public method delete_cliente() as logical

end class

method new() class CRUDClientes; return self

method delete_cliente() class CRUDClientes
    Local lRPC       as logical 
    Local jBodyReq   := jsonObject():new()
    Local jResp      := jsonObject():new()
    Local cError     := ""
    Local cCodigo    := ""
    Local cLoja      := ""
    Local aDados     := {}
    Local nOpc       := 5 // Exclusăo
    Local aLogAuto   := {}
    lRPC := .F.

    Private lMsErroAuto := .F.
    Private aRotina     := {} // Algumas validaçőes do MATA030 pedem essa private

    // 1. Preparaçăo do Ambiente
    IF type('cEmpAnt') == 'U'
        rpcSetEnv('99','01')
        lRPC := .T.
    EndIF

    // 2. Captura do JSON
    cError := jBodyReq:fromJson(oRest:getBodyRequest())
    if !empty(cError)
        jResp['error'] := "JSON Invalido: " + cError
        oRest:setStatusCode(400)
        oRest:setResponse(jResp:toJson())
        if lRPC ; rpcClearEnv() ; endif
        return .T.
    endif

    cCodigo := jBodyReq['codigo']
    cLoja   := jBodyReq['loja']

    // 3. Localizaçăo ANTES da exclusăo
    dbSelectArea("SA1")
    SA1->(dbSetOrder(1))
    
    IF !SA1->(dbSeek(xFilial("SA1") + cCodigo + cLoja))
        jResp['error'] := 'Cliente nao localizado para exclusao.'
        oRest:setStatusCode(404)
        oRest:setResponse(jResp:toJson())
        if lRPC ; rpcClearEnv() ; endif
        return .T.
    ENDIF

    aDados := {;
        {"A1_COD"  , cCodigo , Nil},;
        {"A1_LOJA" , cLoja   , Nil};
    }

    // 4. Execuçăo do ExecAuto
    lMsErroAuto := .F.
    msExecAuto({|x,y| mata030(x,y)}, aDados, nOpc)

    // 5. VALIDAÇĂO DE SUCESSO REAL (O PULO DO GATO)
    // Tentamos buscar o registro de novo. Se NĂO achar, é porque excluiu de verdade!
    dbSelectArea("SA1")
    IF !SA1->(dbSeek(xFilial("SA1") + cCodigo + cLoja))
        
        jResp['codigo'] := cCodigo
        jResp['loja']   := cLoja
        jResp['status'] := 'Cliente excluido com Sucesso!'
        oRest:setStatusCode(200)

    ELSE
        // Se o registro ainda existe, o erro foi real
        aLogAuto := getAutoGRLog()
        
        if ValType(aLogAuto) == "A" .and. Len(aLogAuto) > 0
            cError := aLogAuto[1]
        else
            cError := "Erro de integridade: O cliente possui titulos ou notas e nao pode ser excluido."
        endif
        
        jResp['error'] := alltrim(strTran(cError, "THREAD ERROR", ""))
        oRest:setStatusCode(400)
    ENDIF

    // 6. Resposta única
    oRest:setResponse(jResp:toJson())

    IF lRPC
        rpcClearEnv()
    EndIF

return .T.

method update_cliente() class CRUDClientes
    Local lRPC      as logical
    Local jBodyReq  as json
    Local aDados    as array
    Local nOpc      := 4 // Alteraçăo
    Local jResp     := jsonObject():new()
    Local cError    := ""

    // Private obrigatória para o ExecAuto capturar erros
    Private lMsErroAuto := .F.

    IF type('cEmpAnt') == 'U'
        rpcSetEnv('99','01')
        lRPC := .T.
    EndIF

    // 1. Captura e validaçăo do Body
    jBodyReq := jsonObject():new()
    cError := jBodyReq:fromJson(oRest:getBodyRequest())

    if !empty(cError)
        jResp['error'] := "JSON Invalido: " + cError
        oRest:setStatusCode(400)
        oRest:setResponse(jResp:toJson())
        return .T.
    endif
    cCodigo  := jBodyReq['codigo']
    cLoja    := jBodyReq['loja']
    cNome    := jBodyReq['nome']
    cNomeRed := jBodyReq['nome_fantasia']
    cTipoPes := jBodyReq['tipo']
    cEnd     := jBodyReq['endereco']
    cCidade  := jBodyReq['cidade']
    cEstado  := jBodyReq['estado']

    if empty(cCodigo) .or. empty(cLoja)
        jResp['error'] := "Campos 'codigo' e 'loja' sao obrigatorios no Body."
        oRest:setStatusCode(400)
        oRest:setResponse(jResp:toJson())
        if lRPC ; rpcClearEnv() ; endif
        return .T.
    endif

    // 2. Localizaçăo do registro
    dbSelectArea("SA1")
    SA1->(dbSetOrder(1))
    
    IF !SA1->(dbSeek(xFilial("SA1") + cCodigo + cLoja))
        jResp['error'] := 'Cliente nao encontrado.'
        oRest:setStatusCode(404)
        oRest:setResponse(jResp:toJson())
         if lRPC ; rpcClearEnv() ; endif

        return .T.
    ENDIF
    
    // 3. Montagem dos dados para o MATA030 (Clientes)
    aDados := {;
        {"A1_COD"    , cCodigo  , Nil},;
        {"A1_LOJA"   , cLoja    , Nil},;
        {"A1_NOME"   , cNome    , Nil},;
        {"A1_NREDUZ" , cNomeRed , Nil},;
        {"A1_END"    , cEnd     , Nil},;
        {"A1_EST"    , cEstado  , Nil},;
        {"A1_MUN"    , cCidade  , Nil},;
        {"A1_TIPO"   , cTipoPes , Nil};
    }

    // 4. Execuçăo sem o bloco TRY
    msExecAuto({|x,y| mata030(x,y)}, aDados, nOpc)

    IF lMsErroAuto
        // Pega o erro do log do ExecAuto
        cError := strTran(parseFormat(getAutoGRLog()), "THREAD ERROR", "")
        
        jResp['error'] := alltrim(cError)
        oRest:setStatusCode(500)
        oRest:setResponse(jResp:toJson())
    ELSE
        // Sucesso
        jResp['codigo'] := SA1->A1_COD
        jResp['loja']   := SA1->A1_LOJA
        jResp['nome']   := alltrim(SA1->A1_NOME)
        jResp['status'] := 'Alteracao realizada com Sucesso!'

        oRest:setStatusCode(200) // 200 para OK
        oRest:setResponse(jResp:toJson())
    ENDIF

    IF lRPC
        rpcClearEnv()
    EndIF

return .T.

method incluir_cliente() class CRUDClientes
    Local lRPC       as logical
    Local jBodyReq   := jsonObject():new()
    Local jResp      := jsonObject():new()
    Local aDados     := {}
    Local nOpc       := 3 
    Local cError     := ""
    Local aLogAuto   := {}
    lRPC := .F.

    Private lMsErroAuto := .F.

    IF type('cEmpAnt') == 'U'
        rpcSetEnv('99','01')
        lRPC := .T.
    EndIF

    cError := jBodyReq:fromJson(oRest:getBodyRequest())

    if !empty(cError)
        jResp['error'] := "JSON Invalido: " + cError
        oRest:setStatusCode(400)
        oRest:setResponse(jResp:toJson())
        if lRPC ; rpcClearEnv() ; endif
        return .T.
    endif

    // MONTAGEM DOS DADOS - Adicionei o A1_PESSOA que é vital
    aDados := {;
        {"A1_COD"    , jBodyReq['codigo']         , Nil},;
        {"A1_LOJA"   , jBodyReq['loja']           , Nil},;
        {"A1_NOME"   , jBodyReq['nome']           , Nil},;
        {"A1_NREDUZ" , jBodyReq['nome_fantasia']  , Nil},;
        {"A1_TIPO"   , jBodyReq['tipo']           , Nil},;
        {"A1_PESSOA" , iif(len(alltrim(jBodyReq['tipo'])) > 0, "F", "F") , Nil},; // Ajuste se for J
        {"A1_END"    , jBodyReq['endereco']       , Nil},;
        {"A1_EST"    , jBodyReq['estado']         , Nil},;
        {"A1_MUN"    , jBodyReq['cidade']         , Nil};
    }

    lMsErroAuto := .F.
    
    // MSExecAuto precisa de tratamento de erro robusto
    msExecAuto({|x,y| mata030(x,y)}, aDados, nOpc)

    IF lMsErroAuto
        // Forma segura de pegar o erro sem derrubar a thread
        aLogAuto := getAutoGRLog()
        if valType(aLogAuto) == "A" .and. len(aLogAuto) > 0
            cError := aLogAuto[1]
        else
            cError := "Erro desconhecido no ExecAuto"
        endif

        jResp['success'] := .F.
        jResp['message'] := cError
        
        oRest:setStatusCode(400) // Mudei para 400 para vocę ver o erro do Protheus
        oRest:setResponse(jResp:toJson())
    ELSE
        // Força o posicionamento se o ExecAuto năo o fizer
        dbSelectArea("SA1")
        SA1->(dbSetOrder(1))
        SA1->(dbSeek(xFilial("SA1") + jBodyReq['codigo'] + jBodyReq['loja']))

        jResp['codigo'] := SA1->A1_COD
        jResp['loja']   := SA1->A1_LOJA
        jResp['nome']   := alltrim(SA1->A1_NOME)
        jResp['status'] := 'Cliente incluido com Sucesso!'

        oRest:setStatusCode(201)
        oRest:setResponse(jResp:toJson())
    ENDIF

    IF lRPC
        rpcClearEnv()
    EndIF

return .T.

method recupera_cliente() class CRUDClientes
    
    Local lRPC      as logical
    Local jPathParm as json
    Local jResp     as json
    Local cCodigo   as character
    Local cLoja     as character
    Local aCampos   as array
    Local x         as numeric

    IF type('cEmpAnt') <> 'C'
        rpcSetEnv('99','01')
        lRPC            := .T.
    EndIF 

    jPathParm           := oRest:getPathParamsRequest()
    jResp               := jsonObject():new()

    cCodigo             := jPathParm['codigo']
    cLoja               := jPathParm['loja'  ]

    dbSelectArea("SA1")
    dbSetOrder(1)
    dbSeek(xFilial(alias())+cCodigo+cLoja)

    IF .not. found()
        
        jResp['erro']   := 'Cliente nao encontrado!!'
        
        oRest:setStatusCode(400)
        oRest:setResponse(jResp:toJson())

        return .T.
        
    EndIF

    aCampos               := fwSx3Util():getAllFields(alias(),.F.)

    try

        For x := 1 To Len(aCampos)
            jResp[aCampos[x]] := &(aCampos[x])
        Next 

    catch err
        
        jResp['erro']         := err:errorstack
                                   
        oRest:setFault(jResp:toJson())
        return .T.

    endtry

    oRest:setResponse(jResp:toJson())

    IF lRPC
        rpcClearEnv()
    EndIF

return .T.

method lista_cliente() class CRUDClientes

    Local lRPC          as logical
    Local cErrorStack   as character
    Local cErrorDescr   as character
    Local err           as object
    Local jResp         as json
    Local jCliente      as json

    IF type('cEmpAnt') <> 'C'
        rpcSetEnv('99','01')
        lRPC            := .T.
    EndIF

    try

        jResp           := jsonObject():new()
        jResp['SA1']    := array(0)

        dbSelectArea("SA1")
        dbSetOrder(1)
        dbGoTop()

        While .not. eof()

            jCliente              := jsonObject():new()
            jCliente['codigo'   ] := A1_COD
            jCliente['loja'     ] := A1_LOJA
            jCliente['nome'     ] := alltrim(A1_NOME    )
            jCliente['fantasia' ] := alltrim(A1_NREDUZ  )
            jCliente['endereco' ] := alltrim(A1_END     )

            aadd(jResp['SA1'],jCliente)

            dbSkip()

        Enddo

        oRest:setResponse(jResp:toJson())

    catch err

        cErrorStack     := err:errorstack
        cErrorDescr     := err:description

    endtry   

    IF lRPC
        rpcClearEnv()
    EndIF     

return .T.

